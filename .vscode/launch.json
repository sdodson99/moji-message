{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach Client",
      "type": "chrome",
      "request": "attach",
      "protocol": "inspector",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${webRoot}/*"
      }
    }
  ]
}
